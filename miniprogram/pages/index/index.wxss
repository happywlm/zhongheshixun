/* miniprogram/pages/index/index.wxss */
/* 用户信息栏 */
.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 24rpx 30rpx;
  margin: 20rpx;
  border-radius: 12rpx;
}
.user-info {
  display: flex;
  align-items: center;
}
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
}
.greeting {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}
.logout-btn {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 8rpx 20rpx;
  border: 1rpx solid var(--border);
  border-radius: 999rpx;
}

.banner {
  width: 100%;
  height: 320rpx;
  margin: 20rpx 0;
}
.banner-img {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
}
.banner-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #1677ff;
  font-weight: 600;
}

.entries {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 0;
}
.entry-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}
.entry-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e6f7ff;
  color: #1677ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.entry-icon-img {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 12rpx;
}
.entry-item text { font-size: 26rpx; color: var(--text-secondary); }

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 30rpx 30rpx 10rpx;
}

.skeleton-card { height: 190rpx; margin: 0 20rpx 20rpx; }

.course-list { padding: 0 20rpx; }

/* ========== 统计卡片 ========== */
.stats-card {
  background: #fff;
  border-radius: var(--radius, 16rpx);
  padding: 30rpx;
  margin: 24rpx 20rpx;
}
.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 24rpx;
}
.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #1f2937);
}
.stats-hint {
  font-size: 22rpx;
  color: var(--text-muted, #9ca3af);
}
.stats-grid {
  display: flex;
  justify-content: space-around;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary, #1677ff);
  line-height: 1.2;
}
.stat-label {
  font-size: 22rpx;
  color: var(--text-muted, #9ca3af);
  margin-top: 8rpx;
}

/* ========== 通用 section ========== */
.section {
  margin: 30rpx 20rpx 0;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #1f2937);
}
.section-more {
  font-size: 24rpx;
  color: var(--text-muted, #9ca3af);
}

/* ========== 最近学习 ========== */
.recent-list { display: flex; flex-direction: column; gap: 16rpx; }
.recent-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius, 16rpx);
  padding: 20rpx;
}
.recent-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.recent-cover.placeholder {
  background: #f0f3f7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.recent-info {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}
.recent-title {
  font-size: 28rpx;
  color: var(--text-primary, #1f2937);
  margin-bottom: 12rpx;
}
.progress-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #e5e7eb;
  border-radius: 999rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--primary, #1677ff);
  border-radius: 999rpx;
}
.progress-text {
  font-size: 22rpx;
  color: var(--text-muted, #9ca3af);
  flex-shrink: 0;
}
.recent-btn {
  font-size: 24rpx;
  color: #fff;
  background: var(--primary, #1677ff);
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}
.recent-empty {
  background: #fff;
  border-radius: var(--radius, 16rpx);
  padding: 40rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-muted, #9ca3af);
}

/* ========== 推荐课程 2 列网格 ========== */
.course-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.course-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: var(--radius, 16rpx);
  overflow: hidden;
}
.course-cover {
  width: 100%;
  height: 160rpx;
  display: block;
}
.course-cover.placeholder {
  background: #f0f3f7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}
.course-meta {
  padding: 16rpx;
}
.course-title {
  font-size: 26rpx;
  color: var(--text-primary, #1f2937);
  line-height: 1.4;
  margin-bottom: 12rpx;
  min-height: 72rpx;
}
.course-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.course-tag {
  font-size: 20rpx;
  color: var(--primary, #1677ff);
  background: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}
.course-hours {
  font-size: 20rpx;
  color: var(--text-muted, #9ca3af);
}

/* ========== 通用文本工具 ========== */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ========== 空态 ========== */
.empty {
  background: #fff;
  border-radius: var(--radius, 16rpx);
  padding: 60rpx 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-muted, #9ca3af);
}
.empty-tip {
  font-size: 24rpx;
  margin-top: 12rpx;
  color: var(--text-muted, #9ca3af);
}

/* ========== 底部安全区 ========== */
.safe-bottom {
  height: calc(20rpx + env(safe-area-inset-bottom));
}
