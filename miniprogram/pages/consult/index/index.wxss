/* miniprogram/pages/consult/index/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 输入区 */
.ask-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}
.ask-input {
  width: 100%;
  min-height: 80rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}
.ask-btn {
  margin-top: 16rpx;
  background: #1677ff;
  color: #fff;
  font-size: 30rpx;
  border-radius: 12rpx;
}
.ask-btn--disabled {
  background: #91caff;
}

/* 列表 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.answer-row {
  margin-bottom: 12rpx;
}
.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-q { background: #1677ff; }
.avatar-a { background: #52c41a; }
.avatar-p { background: #faad14; }

.bubble {
  max-width: 78%;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  margin: 0 16rpx;
  word-break: break-all;
}
.bubble-q { background: #e6f0ff; color: #003a8c; }
.bubble-a { background: #f0fae5; color: #135200; }
.bubble-p { background: #fff7e6; color: #873800; }

.meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #999;
  margin-left: 72rpx;
}
.meta-tag {
  color: #1677ff;
}

/* 转人工按钮 */
.action-bar {
  margin-left: 72rpx;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}
.transfer-btn {
  background: #fff7e6 !important;
  color: #d46b08 !important;
  border: 1rpx solid #ffd591 !important;
  font-size: 24rpx !important;
  border-radius: 24rpx !important;
  padding: 0 24rpx !important;
  line-height: 2 !important;
}

.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}
