/* miniprogram/pages/course/study/study.wxss */
/* 课程学习页样式 */

.page {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000;
}

/* 1. 视频播放器 */
.video {
  width: 100%;
  height: 420rpx;
  background: #000;
  flex-shrink: 0;
}

/* 视频占位图（本项目不做真实视频播放） */
.video-poster-wrap {
  width: 100%;
  height: 420rpx;
  position: relative;
  background: #1f1f2e;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.video-poster {
  width: 100%;
  height: 420rpx;
}
.video-poster-tip {
  position: absolute;
  bottom: 24rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

/* 2. 当前章节卡 */
.chapter-card {
  background: #fff;
  padding: 24rpx;
  margin: 16rpx;
  border-radius: var(--radius);
}

.chapter-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.chapter-index {
  font-size: 26rpx;
  color: var(--text-muted);
}

.badge-done {
  background: var(--success);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.chapter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: var(--border);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  min-width: 70rpx;
  text-align: right;
}

.remain-time {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 3. 标记学完按钮 */
.action-row {
  padding: 0 16rpx 16rpx;
  display: flex;
  justify-content: center;
}

.done-tag {
  color: var(--success);
  font-size: 28rpx;
  padding: 12rpx 30rpx;
}

/* 4. 课程信息折叠区 */
.course-info {
  background: #fff;
  padding: 20rpx 24rpx;
  margin: 0 16rpx 16rpx;
  border-radius: var(--radius);
}

.course-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.course-sub {
  font-size: 24rpx;
  color: var(--text-muted);
  display: flex;
  align-items: center;
}

.dot {
  margin: 0 12rpx;
}

/* 5. 章节列表 */
.chapter-list {
  flex: 1;
  background: #fff;
  margin: 0 16rpx 16rpx;
  border-radius: var(--radius);
  padding: 8rpx 0;
  /* 高度由 flex:1 撑开，避免与视频/卡片重叠 */
}

.chapter-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
  transition: background 0.2s;
}

.chapter-item:last-child {
  border-bottom: none;
}

.chapter-item.active {
  background: #e6f0ff;
}

/* 圆形序号 */
.chapter-no {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e5e7eb;
  color: var(--text-secondary);
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.chapter-no.done {
  background: var(--primary);
  color: #fff;
}

.chapter-info {
  flex: 1;
  min-width: 0;
}

.chapter-name {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.chapter-status {
  font-size: 22rpx;
}

.status-done {
  color: var(--success);
}

.status-doing {
  color: var(--primary);
}

.status-todo {
  color: var(--text-muted);
}

/* 6. 空态 */
.empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 28rpx;
}
