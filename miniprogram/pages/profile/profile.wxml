<!-- miniprogram/pages/profile/profile.wxml -->
<view class="profile-page">
  <!-- 用户信息卡 -->
  <view class="user-card">
    <view class="user-bg"></view>
    <view class="user-body">
      <view class="avatar">
        <text wx:if="{{!profile.avatar}}">{{nicknameFirst}}</text>
        <image wx:else src="{{profile.avatar}}" mode="aspectFill"></image>
      </view>
      <view class="user-meta">
        <view class="real-name">{{profile.realName || '学员'}}</view>
        <view class="org-name" wx:if="{{profile.orgName}}">{{profile.orgName}}</view>
        <view class="empty-hint" wx:else>点击下方编辑资料完善信息</view>
      </view>
    </view>
  </view>

  <!-- 学习数据 -->
  <view class="stats-card">
    <view class="stats-title">学习数据</view>
    <view class="stats-grid">
      <view class="stat-item" bindtap="onGoMyCourse">
        <view class="stat-num">{{stats.courseCount}}</view>
        <view class="stat-label">学习课程</view>
      </view>
      <view class="stat-item" bindtap="onGoStudy">
        <view class="stat-num">{{stats.studyHours}}</view>
        <view class="stat-label">学习时长(h)</view>
      </view>
      <view class="stat-item" bindtap="onGoExam">
        <view class="stat-num">{{stats.examCount}}</view>
        <view class="stat-label">考试次数</view>
      </view>
      <view class="stat-item" bindtap="onGoMyConsult">
        <view class="stat-num">{{stats.consultCount}}</view>
        <view class="stat-label">我的咨询</view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="onGoMyCourse">
      <view class="menu-icon" style="background:#e6f7ff;color:#1677ff;">课</view>
      <view class="menu-text">我的课程</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="onGoExam">
      <view class="menu-icon" style="background:#f0fae5;color:#52c41a;">考</view>
      <view class="menu-text">考试记录</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="onGoMyConsult">
      <view class="menu-icon" style="background:#fff4e6;color:#fa8c16;">询</view>
      <view class="menu-text">我的咨询</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="onGoEdit">
      <view class="menu-icon" style="background:#f3e8ff;color:#722ed1;">编</view>
      <view class="menu-text">编辑资料</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="onGoSettings">
      <view class="menu-icon" style="background:#f5f5f5;color:#666;">设</view>
      <view class="menu-text">设置</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="onGoOffline">
      <view class="menu-icon" style="background:#e6fffb;color:#13c2c2;">离</view>
      <view class="menu-text">离线学习</view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="onLogout">退出登录</view>
</view>

<!-- 编辑资料弹窗（简化：action sheet） -->
<view wx:if="{{editVisible}}" class="edit-mask" bindtap="onCloseEdit">
  <view class="edit-sheet" catchtap>
    <view class="sheet-title">编辑资料</view>
    <view class="form-row">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="请输入姓名" value="{{editForm.realName}}" bindinput="onInputRealName" />
    </view>
    <view class="form-row">
      <text class="form-label">手机</text>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{editForm.phone}}" bindinput="onInputPhone" />
    </view>
    <view class="form-row">
      <text class="form-label">机构</text>
      <input class="form-input" placeholder="请输入所属机构" value="{{editForm.orgName}}" bindinput="onInputOrgName" />
    </view>
    <view class="form-row">
      <text class="form-label">岗位</text>
      <picker class="form-input" mode="selector" range="{{jobTypes}}" range-key="label" bindchange="onJobChange">
        <view class="picker-text">{{editForm.jobType || '请选择岗位'}}</view>
      </picker>
    </view>
    <view class="sheet-actions">
      <view class="sheet-btn cancel" bindtap="onCloseEdit">取消</view>
      <view class="sheet-btn confirm" bindtap="onSaveProfile">保存</view>
    </view>
  </view>
</view>
